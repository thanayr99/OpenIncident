# Copy this file to .env.backend and paste your backend-only secrets there.

# Neon/Postgres is the intended deployment database.
# For quick local fallback only, you can temporarily use: sqlite:///data/openincident.db
OPENINCIDENT_DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require
OPENINCIDENT_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
PORT=8000
